# ===========================================
# 智课工坊 - 环境变量配置示例
# ===========================================

# 复制此文件为 .env.local 并填写实际值

# 应用URL（用于生成链接）
NEXT_PUBLIC_APP_URL=http://localhost:5000

# 端口配置
PORT=5000
NODE_ENV=development

# 关闭遥测
NEXT_TELEMETRY_DISABLED=1

# ===========================================
# 生产环境变量（在 Vercel/Docker 中配置）
# ===========================================

# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
